generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Onboarding fields
  username            String?  @unique
  phone               String?
  creditScore         Int      @default(500)
  onboardingComplete  Boolean  @default(false)
  encryptedSeedPhrase String?  // AES-encrypted BIP-39 mnemonic, never returned to client after onboarding

  walletAddress String?        @unique
  token         PersonalToken?
  borrowedLoans Loan[]         @relation("BorrowerLoans")
  lentLoans     Loan[]         @relation("LenderLoans")

  // Loan request relations
  loanRequests         LoanRequest[]        @relation("BorrowerRequests")
  targetedByRequests   LoanRequestLender[]  @relation("LenderTargets")

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tokenHoldings TokenHolding[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum LoanStatus {
  REQUESTED
  ACTIVE
  REPAID
  DEFAULTED
  CANCELLED
}

model PersonalToken {
  id String @id @default(cuid())

  ownerId String @unique
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  tokenName String
  symbol    String

  contractAddress String @unique

  totalSupply Decimal @default(100) @db.Decimal(18, 4)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  loans         Loan[]
  tokenHoldings TokenHolding[]
}

model TokenHolding {
  id      String        @id @default(cuid())
  tokenId String
  token   PersonalToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  holderId String
  holder   User   @relation(fields: [holderId], references: [id], onDelete: Cascade)

  balance Decimal @db.Decimal(18, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tokenId, holderId])
}

model Loan {
  id String @id @default(cuid())

  borrowerId String
  lenderId   String

  borrower User @relation("BorrowerLoans", fields: [borrowerId], references: [id])
  lender   User @relation("LenderLoans", fields: [lenderId], references: [id])

  amountINR         Decimal       @db.Decimal(18, 2)
  collateralTokenId String
  collateralToken   PersonalToken @relation(fields: [collateralTokenId], references: [id])
  collateralAmount  Decimal       @db.Decimal(18, 4)

  txHash String? @unique

  status LoanStatus

  createdAt DateTime  @default(now())
  repaidAt  DateTime?
  durationDays Int     @default(30)
}

// ── Loan Request (pre-Loan) ───────────────────────────────────────────────────

enum LoanRequestType {
  PUBLIC
  TARGETED
}

enum LoanRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

model LoanRequest {
  id         String            @id @default(cuid())
  borrowerId String
  borrower   User              @relation("BorrowerRequests", fields: [borrowerId], references: [id], onDelete: Cascade)

  type          LoanRequestType
  amountINR     Decimal         @db.Decimal(18, 2)
  durationDays  Int
  status        LoanRequestStatus @default(PENDING)
  note          String?           // optional message from borrower

  // Targeted lenders (empty for PUBLIC type)
  targetedLenders LoanRequestLender[]

  // If accepted → references the resulting Loan
  loanId     String? @unique

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model LoanRequestLender {
  id            String      @id @default(cuid())
  loanRequestId String
  loanRequest   LoanRequest @relation(fields: [loanRequestId], references: [id], onDelete: Cascade)

  lenderId String
  lender   User   @relation("LenderTargets", fields: [lenderId], references: [id], onDelete: Cascade)

  status LoanRequestStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([loanRequestId, lenderId])
}
