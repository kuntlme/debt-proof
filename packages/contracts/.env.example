# Contracts Environment Variables

# Sepolia testnet RPC URL (from Alchemy/Infura)
SEPOLIA_RPC_URL=

# Polygon Amoy testnet RPC URL (chainId: 80002)
# Get from: https://alchemy.com or https://infura.io
AMOY_RPC_URL=

# Private key of deployer wallet (with 0x prefix)
# Fund with MATIC on Amoy: https://faucet.polygon.technology/
DEPLOYER_PRIVATE_KEY=

# Etherscan API key for contract verification (Ethereum networks)
ETHERSCAN_API_KEY=

# Polygonscan API key for contract verification (Polygon/Amoy)
# Get from: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=

# Local Hardhat node RPC (default)
# http://127.0.0.1:8545
