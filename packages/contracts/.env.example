# Contracts Environment Variables

# Sepolia testnet RPC URL (from Alchemy/Infura)
SEPOLIA_RPC_URL=

# Private key of deployer wallet (without 0x prefix)
DEPLOYER_PRIVATE_KEY=

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=

# Local Hardhat node RPC (default)
# http://127.0.0.1:8545
